---
import PublicLayout from "@/layouts/PublicLayout.astro";
import Icon from "@/components/ui/Icon.astro";
import { getBioLinks } from "@/lib/db";
import { SITE } from "@/lib/site";
const links = await getBioLinks(Astro.request, Astro.cookies);
---
<PublicLayout
  title="Bio Link Ahzelan"
  description="Semua link penting Ahzelan dalam satu halaman."
  currentPath="/bio-link"
  jsonLd={{ "@context": "https://schema.org", "@type": "Person", name: "Ahzelan", url: SITE.url }}
>
  <main class="min-h-screen bg-royal-50/60 py-12 lg:py-20">
    <div class="mx-auto px-5 text-center" style="max-width: 440px;">
      <img src="/img/ahzelan-portrait.webp" alt="Ahzelan" class="mx-auto rounded-full ring-4 ring-white shadow-lg object-cover" style="width:96px;height:96px;" />
      <h1 class="mt-4 text-[26px] font-extrabold">Ahzelan</h1>
      <p class="text-muted-foreground text-[15px] mb-7">Bantu kamu tumbuh di era digital 🌱</p>
      <div class="flex flex-col gap-3">
        {links.map((l) => {
          const target = l.href === "wa" ? `https://wa.me/${SITE.whatsapp}` : l.href;
          const isExt = target.startsWith("http");
          return (
            <a
              href={target}
              target={isExt ? "_blank" : undefined}
              rel={isExt ? "noopener" : undefined}
              onclick={!isExt && l.is_accent ? "window.dispatchEvent(new Event('ahz:open-contact')); return false;" : undefined}
              class:list={["flex items-center gap-3.5 w-full text-left cursor-pointer rounded-2xl px-4.5 py-3.5 transition-all hover:-translate-y-0.5", l.is_accent ? "bg-primary text-white shadow-brand" : "bg-white border border-border shadow-xs"]}
              style="padding: 14px 18px;"
            >
              <span
                class="w-10.5 h-10.5 rounded-xl flex items-center justify-center shrink-0"
                style={`width:42px;height:42px;border-radius:12px;background:${l.is_accent ? "rgba(255,255,255,.2)" : "var(--brand-primary-soft)"};color:${l.is_accent ? "#fff" : "var(--brand-primary)"};`}
              >
                <Icon name={l.icon} size={22} />
              </span>
              <span class="flex-1">
                <span class="block font-display font-bold text-[15px]">{l.label}</span>
                <span class="block text-[13px] opacity-80">{l.sub_text}</span>
              </span>
              <Icon name="arrow-up-right" size={18} class="opacity-60" />
            </a>
          );
        })}
      </div>
      <div class="mt-8 text-sm text-muted-foreground">ahzelan.com</div>
    </div>
  </main>
</PublicLayout>
