---
import AdminLayout from "@/layouts/AdminLayout.astro";
import EntityManager from "@/components/admin/EntityManager";
import { getAdminClient } from "@/lib/supabase";
export const prerender = false;

const admin = getAdminClient();
let rows: any[] = [];
if (admin) {
  const { data } = await admin.from("gallery_items").select("*").order("sort_order");
  if (data) rows = data;
}

const columns = [
  { key: "image_url", label: "Gambar", render: (r: any) => r.image_url ? `<img src="${r.image_url}" class="w-10 h-10 rounded object-cover" />` : "—" },
  { key: "caption", label: "Caption", className: "font-display" },
  { key: "sort_order", label: "Urutan", hideOn: "sm" },
  { key: "is_visible", label: "Status" },
];
const fields = [
  { type: "media", name: "media_id", label: "Gambar", urlTarget: "image_url", help: "Pilih dari media library — URL terisi otomatis" },
  { type: "url", name: "image_url", label: "URL Gambar", required: true, help: "Terisi otomatis saat pilih media, atau isi manual" },
  { type: "text", name: "caption", label: "Caption" },
  { type: "number", name: "aspect_w", label: "Aspek Lebar" },
  { type: "number", name: "aspect_h", label: "Aspek Tinggi" },
  { type: "number", name: "sort_order", label: "Urutan" },
  { type: "boolean", name: "is_visible", label: "Tampilkan" },
];
---
<AdminLayout title="Galeri" currentPath="/admin/gallery" crumbs={[{ label: "Admin", href: "/admin/dashboard" }, { label: "Galeri" }]}>
  <EntityManager client:load title="Galeri" endpoint="/api/admin/gallery" rows={rows} columns={columns} searchKeys={["caption"]} fields={fields} />
</AdminLayout>
