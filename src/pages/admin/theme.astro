---
import AdminLayout from "@/layouts/AdminLayout.astro";
import ThemeManager from "@/components/admin/ThemeManager";
import { getAdminClient } from "@/lib/supabase";
export const prerender = false;

const admin = getAdminClient();
let initial = { primary_color: "#2e4191", radius: "12px" };
if (admin) {
  const { data } = await admin.from("site_settings").select("primary_color,radius").eq("id", 1).single();
  if (data?.primary_color) initial.primary_color = data.primary_color;
  if (data?.radius) initial.radius = data.radius;
}
---
<AdminLayout title="Tema" currentPath="/admin/theme" crumbs={[{ label: "Admin", href: "/admin/dashboard" }, { label: "Tema" }]}>
  <ThemeManager client:load initial={initial} />
</AdminLayout>
