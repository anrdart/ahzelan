---
import AdminLayout from "@/layouts/AdminLayout.astro";
import EntityManager from "@/components/admin/EntityManager";
import { getAdminClient } from "@/lib/supabase";
import { FALLBACK_RECOMMENDATIONS } from "@/lib/fallback";
export const prerender = false;

const admin = getAdminClient();
let rows = FALLBACK_RECOMMENDATIONS as any[];
if (admin) {
  const { data } = await admin.from("recommendations").select("*").order("sort_order");
  if (data) rows = data;
}

const columns = [
  { key: "title", label: "Produk", className: "font-display font-semibold" },
  { key: "category", label: "Kategori" },
  { key: "badge", label: "Badge", hideOn: "sm" },
  { key: "is_visible", label: "Status" },
];
const fields = [
  { type: "media", name: "image_id", label: "Gambar" },
  { type: "select", name: "icon", label: "Ikon", help: "Tampil di kartu rekomendasi.", options: [
    { value: "layout-template", label: "Template" },
    { value: "server", label: "Server / Hosting" },
    { value: "puzzle", label: "Plugin" },
    { value: "extension", label: "Ekstensi" },
    { value: "credit-card", label: "Pembayaran" },
    { value: "shopping-bag", label: "Toko / Produk" },
    { value: "palette", label: "Desain" },
    { value: "search", label: "Riset / SEO" },
    { value: "code", label: "Kode / Dev" },
    { value: "package", label: "Paket" },
    { value: "newspaper", label: "Konten / Blog" },
    { value: "megaphone", label: "Iklan" },
    { value: "globe", label: "Website" },
    { value: "zap", label: "Performa" },
    { value: "star", label: "Favorit" },
    { value: "rocket", label: "Launch" },
    { value: "graduation-cap", label: "Belajar" },
    { value: "link", label: "Tautan" },
  ] },
  { type: "text", name: "title", label: "Nama Produk", required: true },
  { type: "text", name: "category", label: "Kategori", required: true, help: "Hosting, Plugin, Payment, Template, Tools" },
  { type: "textarea", name: "description", label: "Deskripsi" },
  { type: "url", name: "link_url", label: "Link Affiliate/Detail" },
  { type: "text", name: "badge", label: "Badge", placeholder: "Rekomendasi / Favorit" },
  { type: "number", name: "sort_order", label: "Urutan" },
  { type: "boolean", name: "is_visible", label: "Tampilkan" },
];
---
<AdminLayout title="Rekomendasi" currentPath="/admin/recommendations" crumbs={[{ label: "Admin", href: "/admin/dashboard" }, { label: "Rekomendasi" }]}>
  <EntityManager client:load title="Rekomendasi" endpoint="/api/admin/recommendations" rows={rows} columns={columns} searchKeys={["title", "category"]} fields={fields} />
</AdminLayout>
