---
import Icon from "@/components/ui/Icon.astro";
import FaqAccordion from "@/components/public/FaqAccordion";
import type { Faq } from "@/lib/types";

interface Props { items: Faq[]; withSearchCta?: boolean }
const { items, withSearchCta = true } = Astro.props as Props;
---
<section class="py-12">
  <div class="container-ahz" style="max-width: 820px;">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 text-primary font-bold text-sm font-display uppercase tracking-wider mb-3"><Icon name="sparkles" size={15} /> FAQ</div>
      <h2 class="text-[clamp(28px,4vw,40px)] font-extrabold">Masih ada yang ditanyain?</h2>
    </div>
    <FaqAccordion client:visible items={items.map((f) => ({ question: f.question, answer: f.answer }))} />
    {withSearchCta && (
      <div class="text-center mt-7">
        <button onclick="window.dispatchEvent(new Event('ahz:open-contact'))" class="inline-flex items-center gap-2 px-3 py-2 rounded-md font-display font-semibold text-primary hover:bg-royal-50 transition-colors">
          <Icon name="message-circle" size={18} /> Ada yang kurang jelas? Chat Ahzelan sini
        </button>
      </div>
    )}
  </div>
</section>
