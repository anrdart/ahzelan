---
import Icon from "@/components/ui/Icon.astro";
import { Badge } from "@/components/ui/badge";
import type { Service } from "@/lib/types";

interface Props { services: Service[] }
const { services } = Astro.props as Props;
---
<section class="py-12">
  <div class="container-ahz">
    <div class="text-center max-w-2xl mx-auto mb-12 ahz-reveal">
      <div class="inline-flex items-center gap-2 text-primary font-bold text-sm font-display uppercase tracking-wider mb-3">
        <Icon name="sparkles" size={15} /> Layanan
      </div>
      <h2 class="text-[clamp(28px,4vw,40px)] font-extrabold">Semua yang bisnis kamu butuhin</h2>
      <p class="text-muted-foreground text-lg mt-3.5 leading-relaxed">Dari yang baru mulai sampai yang mau scaling — dikerjain rapi, hasilnya kelihatan.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((s) => (
        <a href={s.cta_url || "/layanan"} class:list={["ahz-card-lift block rounded-lg border border-border bg-card p-7", s.title === "Jasa Landing Page" ? "ring-1 ring-primary/20" : ""]}>
          <div
            class:list={["w-13 h-13 rounded-2xl flex items-center justify-center mb-5"]}
            style={`width:52px;height:52px;border-radius:14px;background:${s.title === "Jasa Landing Page" ? "var(--brand-gradient)" : "var(--brand-primary-soft)"};color:${s.title === "Jasa Landing Page" ? "#fff" : "var(--brand-primary)"};`}
          >
            <Icon name={s.icon || "package"} size={26} />
          </div>
          <div class="flex items-center gap-2 mb-1.5">
            <h3 class="text-xl font-bold">{s.title}</h3>
            {s.title === "Jasa Landing Page" && <Badge variant="default">Unggulan</Badge>}
          </div>
          <p class="text-muted-foreground text-[15px] leading-relaxed mb-3.5">{s.description}</p>
          <span class="inline-flex items-center gap-1.5 text-primary font-bold text-sm font-display">Selengkapnya <Icon name="arrow-right" size={14} /></span>
        </a>
      ))}
    </div>
  </div>
</section>
