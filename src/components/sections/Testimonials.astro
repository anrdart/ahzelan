---
import Icon from "@/components/ui/Icon.astro";
import { Avatar } from "@/components/ui/avatar";
import type { Testimonial } from "@/lib/types";

interface Props { items: Testimonial[] }
const { items } = Astro.props as Props;
---
<section class="py-12">
  <div class="container-ahz">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <div class="inline-flex items-center gap-2 text-primary font-bold text-sm font-display uppercase tracking-wider mb-3"><Icon name="sparkles" size={15} /> Testimoni</div>
      <h2 class="text-[clamp(28px,4vw,40px)] font-extrabold">Kata mereka yang udah kerja bareng</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((t) => (
        <div class="rounded-lg border border-border bg-card p-6">
          <div class="flex gap-1 text-amber-500 mb-3.5">
            {Array.from({ length: t.rating || 5 }).map(() => (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <p class="text-base leading-relaxed text-foreground mb-5">"{t.quote}"</p>
          <div class="flex items-center gap-3">
            <Avatar name={t.name} size="md" />
            <div>
              <div class="font-display font-bold text-[15px]">{t.name}</div>
              <div class="text-sm text-muted-foreground">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
