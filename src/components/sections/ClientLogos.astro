---
import { CLIENT_LOGOS } from "@/lib/site";
---
<section class="py-12">
  <div class="container-ahz">
    <div class="text-center max-w-2xl mx-auto mb-10">
      <div class="inline-flex items-center gap-2 text-primary font-bold text-sm font-display uppercase tracking-wider mb-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Dipercaya banyak bisnis
      </div>
      <h2 class="text-[clamp(26px,4vw,36px)] font-extrabold">Karya yang udah jalan bareng Ahzelan</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 items-center">
      {CLIENT_LOGOS.map((c) => (
        <div class="flex items-center justify-center p-5 bg-white rounded-xl border border-border grayscale hover:grayscale-0 opacity-80 hover:opacity-100 transition-all duration-300" title={c.name}>
          <img src={c.src} alt={c.name} loading="lazy" class="max-h-10 w-auto max-w-full object-contain" />
        </div>
      ))}
    </div>
  </div>
</section>
