---
/**
 * <Icon name="..." /> — server-rendered Lucide SVG, zero JS.
 * Use across .astro pages; React island variant is `./icon.tsx`.
 */
import { ICONS } from "./icons";

interface Props {
  name: string;
  size?: number;
  class?: string;
  stroke?: number;
  "aria-hidden"?: boolean;
}
const { name, size = 20, class: className = "", stroke = 2, "aria-hidden": ariaHidden = true } = Astro.props;
const body = ICONS[name] ?? "";
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={ariaHidden ? "true" : undefined}
  set:html={body}
/>
